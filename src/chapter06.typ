#pad(left: 0.6em)[
#grid(
  columns: (1.3em, 1fr),
  row-gutter: 0.5em,
  [1.], [The Hasan Ali Dholakawala Trust — a mother-and-child centre.],
  [2.], [The Musaqqati Charitable Trust \[name uncertain\].],
  [3.], [The Morris Wala travellers' lodge \[name uncertain\].],
  [4.], [The Kanadi-wali Colony \[name uncertain\].],
